# Supabase project credentials (from https://supabase.com/dashboard/project/_/settings/api)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# GitHub OAuth (for local dev with supabase CLI)
SUPABASE_AUTH_GITHUB_CLIENT_ID=your-github-oauth-client-id
SUPABASE_AUTH_GITHUB_SECRET=your-github-oauth-client-secret
