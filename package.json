{
  "name": "termcanvas",
  "version": "0.25.11",
  "description": "An infinite canvas desktop app for visually managing terminals",
  "main": "dist-electron/main.js",
  "bin": {
    "termcanvas": "./dist-cli/termcanvas.js",
    "hydra": "./dist-cli/hydra.js",
    "browse": "./dist-cli/browse.js"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "generate:icons": "python3 scripts/generate-icons.py",
    "postinstall": "electron-builder install-app-deps && npx playwright install chromium",
    "typecheck": "tsc --noEmit",
    "typecheck:headless": "tsc --noEmit -p tsconfig.headless.json",
    "build:headless": "tsc -p tsconfig.headless.build.json",
    "test": "tsx --test \"tests/**/*.test.{ts,tsx}\"",
    "test:hydra": "tsx --test \"hydra/tests/**/*.test.ts\"",
    "test:browse": "tsx --test \"browse/tests/**/*.test.ts\"",
    "test:eval": "tsx --test \"eval/tests/**/*.test.ts\"",
    "test:all": "npm test && npm run test:hydra && npm run test:browse && npm run test:eval"
  },
  "keywords": [
    "terminal",
    "canvas",
    "electron",
    "worktree",
    "git",
    "xterm",
    "infinite-canvas",
    "developer-tools"
  ],
  "author": {
    "name": "Doan Bac Tam",
    "email": "doanbactam@users.noreply.github.com"
  },
  "homepage": "https://github.com/doanbactam/termcanvas",
  "repository": {
    "type": "git",
    "url": "https://github.com/doanbactam/termcanvas.git"
  },
  "bugs": {
    "url": "https://github.com/doanbactam/termcanvas/issues"
  },
  "license": "MIT",
  "type": "module",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.81.0",
    "@aws-sdk/client-s3": "^3.1019.0",
    "@supabase/supabase-js": "^2.99.3",
    "@xterm/addon-image": "^0.9.0",
    "@xterm/addon-serialize": "^0.14.0",
    "@xyflow/react": "^12.10.1",
    "adm-zip": "^0.5.16",
    "electron-updater": "^6.8.3",
    "geist": "^1.7.0",
    "marked": "^17.0.4",
    "node-pty": "^1.1.0",
    "perfect-freehand": "^1.2.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "ws": "^8.20.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@types/adm-zip": "^0.5.8",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.7.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "playwright": "^1.52.0",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6"
  }
}
