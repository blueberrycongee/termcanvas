# TermCanvas Cloud Configuration

# --- Server ---

# API authentication token (required for remote access)
TERMCANVAS_API_TOKEN=

# Host to bind to (default: 0.0.0.0)
TERMCANVAS_HOST=0.0.0.0

# Port to listen on (default: 7080)
TERMCANVAS_PORT=7080

# TermCanvas instance name controls the state directory name
# prod -> ~/.termcanvas, dev -> ~/.termcanvas-dev
TERMCANVAS_INSTANCE=prod

# Host path that docker-compose bind-mounts into the container workspace root
HOST_WORKSPACE_DIR=./_workspace

# Workspace root inside the container.
# Remote `termcanvas workflow` / `termcanvas worktree` commands must use paths
# visible from inside the container, for example `/workspace/my-repo`.
WORKSPACE_DIR=/workspace

# --- Rate Limiting ---

# Max requests per minute per IP (0 or unset = no limit)
TERMCANVAS_RATE_LIMIT=

# --- CORS ---

# Comma-separated list of allowed origins (unset = no CORS headers)
# Example: https://dashboard.example.com,https://admin.example.com
TERMCANVAS_CORS_ORIGINS=

# --- Observability ---

# Optional lifecycle webhook endpoint for server, terminal, and workflow events
TERMCANVAS_WEBHOOK_URL=

# Optional shared secret used to sign webhook payloads in X-Webhook-Signature
TERMCANVAS_WEBHOOK_SECRET=

# Build-time agent CLI package installed into the image by docker-compose
TERMCANVAS_AGENT_CLI_PACKAGE=@openai/codex

# --- AI Provider Keys ---
# Passed through to spawned terminal processes

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=

# --- Cloud Task Configuration ---

# Unique task identifier for cloud execution
TASK_ID=

# Optional callback URL that receives heartbeat payloads every 10 seconds while
# the headless server is running.
RESULT_CALLBACK_URL=

# Optional task metadata consumed by higher-level cloud orchestration.
GIT_REPO_URL=

# Reserved for higher-level artifact upload workflows
S3_ENDPOINT=
S3_BUCKET=
