---
export interface Props {
  href: string;
  title: string;
  date: Date;
  summary: string;
  tag?: string;
  cover?: string;
}

const { href, title, date, summary, tag, cover } = Astro.props;

const formatter = new Intl.DateTimeFormat("zh-CN", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
const dateLabel = formatter.format(date);
---

<a class="article-card" href={href}>
  {
    cover && (
      <div class="card-cover">
        <img src={cover} alt="" loading="lazy" />
      </div>
    )
  }
  <div class="card-body">
    <div class="card-meta">
      {tag && <span class="card-tag">{tag}</span>}
      <time class="card-date" datetime={date.toISOString()}>{dateLabel}</time>
    </div>
    <h3 class="card-title">{title}</h3>
    <p class="card-summary">{summary}</p>
    <span class="card-cta">阅读全文 →</span>
  </div>
</a>

<style>
  .article-card {
    display: flex;
    flex-direction: column;
    background: var(--color-card);
    border: 1px solid var(--color-border-soft);
    border-radius: 12px;
    overflow: hidden;
    transition:
      background 0.2s ease,
      border-color 0.2s ease,
      transform 0.2s ease,
      box-shadow 0.2s ease;
  }
  .article-card:hover {
    background: var(--color-card-hover);
    border-color: var(--color-border-strong);
    transform: translateY(-2px);
    box-shadow: 0 14px 30px -22px rgba(20, 17, 10, 0.22);
  }
  .card-cover {
    aspect-ratio: 16 / 9;
    background: var(--color-surface-sunken);
    border-bottom: 1px solid var(--color-border-soft);
    overflow: hidden;
  }
  .card-cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }
  .article-card:hover .card-cover img {
    transform: scale(1.02);
    transition: transform 0.4s ease;
  }
  .card-body {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1.5rem 1.5rem 1.65rem;
    flex: 1;
  }
  .card-meta {
    display: flex;
    gap: 0.75rem;
    align-items: center;
    font-size: 0.78rem;
    font-family: var(--font-mono);
    color: var(--color-ink-faint);
  }
  .card-tag {
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .card-title {
    margin-top: 0.25rem;
    font-size: 1.2rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    line-height: 1.3;
    color: var(--color-ink);
  }
  .card-summary {
    color: var(--color-ink-muted);
    line-height: 1.6;
    font-size: 0.95rem;
  }
  .card-cta {
    margin-top: auto;
    color: var(--color-accent);
    font-size: 0.9rem;
    font-weight: 500;
    padding-top: 0.5rem;
  }
</style>
