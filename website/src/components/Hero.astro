---
import { defaultLocale, siteCopy, type Locale } from "../lib/site";

export interface Props {
  locale?: Locale;
}

const { locale = defaultLocale } = Astro.props;
const copy = siteCopy[locale].hero;
---

<section class="hero">
  <div class="container-page">
    <div class="hero-grid">
      <div class="hero-copy">
        <span class="label-mono">{copy.eyebrow}</span>
        <h1 class="hero-title">{copy.title}</h1>
        <p class="hero-tagline">{copy.tagline}</p>
        <div class="hero-actions">
          <a class="btn btn-primary" href="https://github.com/blueberrycongee/termcanvas/releases">
            <span>{copy.download}</span>
            <svg
              class="btn-arrow"
              xmlns="http://www.w3.org/2000/svg"
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <line x1="5" y1="12" x2="19" y2="12"></line>
              <polyline points="13 6 19 12 13 18"></polyline>
            </svg>
          </a>
          <a class="btn btn-secondary" href="https://github.com/blueberrycongee/termcanvas">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="currentColor"
              aria-hidden="true"
            >
              <path
                d="M12 .3a12 12 0 0 0-3.8 23.4c.6.1.8-.3.8-.6v-2.1c-3.3.7-4-1.6-4-1.6-.6-1.4-1.4-1.8-1.4-1.8-1.1-.7.1-.7.1-.7 1.2.1 1.9 1.3 1.9 1.3 1.1 1.9 2.9 1.3 3.6 1 .1-.8.4-1.3.8-1.6-2.7-.3-5.5-1.3-5.5-5.9 0-1.3.5-2.4 1.3-3.2-.1-.4-.6-1.6.1-3.3 0 0 1-.3 3.3 1.2a11.5 11.5 0 0 1 6 0c2.3-1.5 3.3-1.2 3.3-1.2.7 1.7.2 2.9.1 3.3.8.8 1.3 1.9 1.3 3.2 0 4.6-2.8 5.6-5.5 5.9.4.4.8 1.1.8 2.2v3.3c0 .3.2.7.8.6A12 12 0 0 0 12 .3"
              ></path>
            </svg>
            <span>{copy.github}</span>
          </a>
        </div>
        <p class="hero-meta">{copy.meta}</p>
      </div>
      <div class="hero-art">
        <div class="hero-art-frame">
          <img src="/hero-canvas.png" alt={copy.imageAlt} loading="eager" />
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    padding: 5rem 0 4rem;
  }
  @media (min-width: 768px) {
    .hero {
      padding: 7rem 0 5rem;
    }
  }
  .hero-grid {
    display: grid;
    gap: 3rem;
    align-items: center;
  }
  @media (min-width: 1024px) {
    .hero-grid {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1.15fr);
      gap: 5rem;
    }
  }
  .hero-title {
    margin-top: 1rem;
    font-size: clamp(2.25rem, 4.6vw, 3.75rem);
    line-height: 1.05;
    letter-spacing: -0.02em;
    font-weight: 600;
  }
  .hero-tagline {
    margin-top: 1.5rem;
    color: var(--color-ink-muted);
    font-size: 1.125rem;
    line-height: 1.6;
    max-width: 36rem;
  }
  .hero-actions {
    margin-top: 2rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }
  .hero-meta {
    margin-top: 1.25rem;
    font-size: 0.85rem;
    color: var(--color-ink-faint);
  }
  .hero-art-frame {
    position: relative;
    border-radius: 14px;
    overflow: hidden;
    border: 1px solid var(--color-border);
    background: var(--color-card);
    box-shadow: var(--shadow-card);
  }
  .hero-art-frame img {
    width: 100%;
    display: block;
  }
</style>
