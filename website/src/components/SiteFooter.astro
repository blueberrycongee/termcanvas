---
import { articlesPath, defaultLocale, siteCopy, type Locale } from "../lib/site";

export interface Props {
  locale?: Locale;
}

const { locale = defaultLocale } = Astro.props;
const copy = siteCopy[locale];
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container-page py-10 text-sm">
    <div class="grid gap-8 md:grid-cols-3">
      <div>
        <div class="brand-row">
          <img class="brand-logo" src="/logo.svg" alt="" width="24" height="24" />
          <span class="brand-name">TermCanvas</span>
        </div>
        <p class="muted mt-2">{copy.footer.tagline}</p>
      </div>
      <div>
        <div class="label-mono mb-3">{copy.footer.project}</div>
        <ul class="space-y-1.5">
          <li>
            <a class="link" href="https://github.com/blueberrycongee/termcanvas">{copy.footer.repository}</a>
          </li>
          <li>
            <a class="link" href="https://github.com/blueberrycongee/termcanvas/releases"
              >{copy.footer.releases}</a
            >
          </li>
          <li>
            <a class="link" href="https://github.com/blueberrycongee/termcanvas/issues">{copy.footer.issues}</a>
          </li>
        </ul>
      </div>
      <div>
        <div class="label-mono mb-3">{copy.footer.reading}</div>
        <ul class="space-y-1.5">
          <li><a class="link" href={articlesPath(locale)}>{copy.footer.articles}</a></li>
          <li>
            <a class="link" href="https://github.com/blueberrycongee/termcanvas/blob/main/README.md"
              >{copy.footer.readme}</a
            >
          </li>
        </ul>
      </div>
    </div>
    <div class="muted mt-10 pt-6 border-t copyright">
      © {year} TermCanvas. MIT License.
    </div>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--color-border);
    background: var(--color-surface);
    margin-top: 6rem;
  }
  .brand-row {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 600;
  }
  .brand-logo {
    width: 1.25rem;
    height: 1.25rem;
    display: block;
  }
  .muted {
    color: var(--color-ink-muted);
  }
  .copyright {
    border-color: var(--color-border);
  }
  .link {
    color: var(--color-ink-muted);
    transition: color 0.15s ease;
  }
  .link:hover {
    color: var(--color-accent);
  }
</style>
